{
    "name": "pb2mapconverter",
    "version": "1.0.0",
    "description": "Converts a given Plazma Burst 2 .xml map to a Plazma Burst 3 equivalent.",
    "main": "index.js",
    "scripts": {
        "dev": "tsx --env-file=.env --watch src/index.ts",
        "start": "node --env-file=.env dist/index.js",
        "build": "tsc -p tsconfig.build.json",
        "test": "vitest",
        "test:run": "vitest --run",
        "test:ui": "vitest --ui",
        "coverage": "vitest run --coverage",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint --fix ."
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nyoveee/pb2mapconverter.git"
    },
    "imports": {
        "#*": "./src/*"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/Nyoveee/pb2mapconverter/issues"
    },
    "homepage": "https://github.com/Nyoveee/pb2mapconverter#readme",
    "dependencies": {
        "express": "^5.2.1",
        "multer": "^2.1.1",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/node22": "^22.0.5",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.9.1",
        "@types/xml2js": "^0.4.14",
        "@vitest/coverage-v8": "^4.1.8",
        "@vitest/eslint-plugin": "^1.6.19",
        "eslint": "^10.4.1",
        "eslint-plugin-perfectionist": "^5.9.0",
        "prettier": "^3.8.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vitest": "^4.1.8"
    }
}
